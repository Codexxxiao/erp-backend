generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  email      String   @unique
  nickname   String?
  createTime DateTime @default(now())
  // 用户与角色：多对多关联
  roles      Role[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique // 角色唯一标识，如 admin、user
  label       String       // 角色显示名称，如 超级管理员、普通用户
  description String?
  createdAt   DateTime     @default(now())
  // 反向关联
  users       User[]
  permissions Permission[]
}

model Permission {
  id          Int    @id @default(autoincrement())
  code        String @unique // 权限唯一标识，如 user:list、user:add
  label       String // 权限显示名称，如 用户列表、新增用户
  type        String? // 权限类型，如 menu、button
  description String?
  createdAt   DateTime @default(now())
  // 反向关联
  roles       Role[]
}